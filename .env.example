# KiraPass OS — Environment Variables (örnek)
# Gerçek değerleri ASLA commit etme. Kaynak: apps/api/src kod tabanı.

# Database (Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/kirapass_dev

# JWT (access token; üretimde fail-fast: JWT_SECRET >= 32 karakter olmalı)
JWT_SECRET=change-me-min-32-characters-strong-secret
JWT_ACCESS_EXPIRES_IN=15m
# Not: refresh token opaque (SHA-256, DB'de saklanır); ayrı JWT refresh secret yoktur.

# App
PORT=3000
NODE_ENV=development

# CORS (virgülle ayrılmış origin allowlist; boşsa prod'da cross-origin reddedilir)
CORS_ORIGINS=http://localhost:3000

# Diagnostics (prod'da /metrics, /health/info, /_internal/* için x-internal-token)
DIAGNOSTICS_TOKEN=change-me-prod-internal-token

# Incident analyzer (opsiyonel; yoksa AI analizi atlanır)
GEMINI_API_KEY=

# Opsiyonel — prod 5xx hata bildirimleri için. Boşsa alerting sessizce devre dışı.
DISCORD_WEBHOOK_URL=
