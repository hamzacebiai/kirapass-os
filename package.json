{
  "name": "kirapass-os",
  "version": "1.0.0",
  "private": true,
  "description": "KiraPass OS — PropTech SaaS AI Operating System",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/api",
    "build": "npm run build --workspace=apps/api",
    "test": "npm run test --workspace=apps/api",
    "test:cov": "npm run test:cov --workspace=apps/api",
    "db:generate": "npm run generate --workspace=packages/database",
    "db:migrate": "npm run migrate --workspace=packages/database",
    "check:port3000": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-safety.ps1 -Action check-port -Port 3000",
    "check:port5432": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-safety.ps1 -Action check-port -Port 5432",
    "port:pid": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-safety.ps1 -Action find-pid -Port 3000",
    "port:pid3000": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-safety.ps1 -Action find-pid -Port 3000",
    "kill:pid": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-safety.ps1 -Action kill-pid",
    "prisma:safe-generate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-safety.ps1 -Action safe-generate"
  },
  "author": "Atalay Hamzaçebi",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1"
  }
}
