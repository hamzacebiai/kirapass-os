generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agency {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  email     String   @unique
  phone     String?
  isActive         Boolean          @default(true)
  subscriptionTier SubscriptionTier @default(BASIC)
  status           AgencyStatus     @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  users            User[]
  properties       Property[]
  tenants          Tenant[]
  owners           Owner[]

  @@map("agencies")
}

model User {
  id            String         @id @default(uuid())
  agencyId      String
  email         String         @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          UserRole       @default(AGENT)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  agency        Agency         @relation(fields: [agencyId], references: [id])
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id           String    @id @default(uuid())
  token        String    @unique
  userId       String
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Property {
  id         String         @id @default(uuid())
  agencyId   String
  title      String
  addressLine String
  city       String
  district   String?
  postalCode String?
  notes      String?
  type       PropertyType   @default(RESIDENTIAL)
  status     PropertyStatus @default(ACTIVE)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  agency     Agency         @relation(fields: [agencyId], references: [id])
  ownerId    String?
  owner      Owner?         @relation(fields: [ownerId], references: [id])
  units      Unit[]

  @@index([agencyId])
  @@index([ownerId])
  @@map("properties")
}

model Unit {
  id         String     @id @default(uuid())
  agencyId   String
  propertyId String
  name       String
  unitNumber String
  floor      String?
  notes      String?
  type       UnitType   @default(APARTMENT)
  status     UnitStatus @default(ACTIVE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  property   Property   @relation(fields: [propertyId], references: [id])
  leases     Lease[]

  @@index([agencyId])
  @@index([propertyId])
  @@map("units")
}

model Lease {
  id            String      @id @default(uuid())
  agencyId      String
  unitId        String
  startDate     DateTime
  endDate       DateTime
  rentAmount    Decimal     @db.Decimal(12, 2)
  depositAmount Decimal?    @db.Decimal(12, 2)
  notes         String?
  status        LeaseStatus @default(ACTIVE)
  tenantId      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  unit          Unit           @relation(fields: [unitId], references: [id])
  tenant        Tenant?        @relation(fields: [tenantId], references: [id])
  rentSchedules RentSchedule[]

  @@index([agencyId])
  @@index([unitId])
  @@index([tenantId])
  @@map("leases")
}

model RentSchedule {
  id        String             @id @default(uuid())
  agencyId  String
  leaseId   String
  tenantId  String?
  dueDate   DateTime
  amount    Decimal            @db.Decimal(12, 2)
  status    RentScheduleStatus @default(PENDING)
  notes     String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  lease     Lease              @relation(fields: [leaseId], references: [id])
  tenant    Tenant?            @relation(fields: [tenantId], references: [id])
  payments  Payment[]

  @@index([agencyId])
  @@index([leaseId])
  @@index([tenantId])
  @@map("rent_schedules")
}

enum RentScheduleStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Payment {
  id             String        @id @default(uuid())
  agencyId       String
  rentScheduleId String
  tenantId       String?
  amount         Decimal       @db.Decimal(12, 2)
  paidAt         DateTime
  method         PaymentMethod @default(CASH)
  reference      String?
  status         PaymentStatus @default(COMPLETED)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  rentSchedule   RentSchedule  @relation(fields: [rentScheduleId], references: [id])
  tenant         Tenant?       @relation(fields: [tenantId], references: [id])

  @@index([agencyId])
  @@index([rentScheduleId])
  @@index([tenantId])
  @@map("payments")
}

model AuditLog {
  id            String   @id @default(uuid())
  eventType     String
  action        String
  resource      String
  method        String?
  statusCode    Int?
  userId        String?
  agencyId      String?
  correlationId String?
  ip            String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([agencyId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
  VOIDED
}

model Tenant {
  id         String       @id @default(uuid())
  agencyId   String
  firstName  String
  lastName   String
  email      String?
  phone      String?
  nationalId String?
  notes      String?
  status     TenantStatus @default(ACTIVE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  agency        Agency         @relation(fields: [agencyId], references: [id])
  leases        Lease[]
  rentSchedules RentSchedule[]
  payments      Payment[]

  @@index([agencyId])
  @@map("tenants")
}

enum TenantStatus {
  ACTIVE
  ARCHIVED
}

model Owner {
  id         String      @id @default(uuid())
  agencyId   String
  firstName  String
  lastName   String
  email      String?
  phone      String?
  status     OwnerStatus @default(ACTIVE)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  agency     Agency      @relation(fields: [agencyId], references: [id])
  properties Property[]

  @@index([agencyId])
  @@map("owners")
}

enum OwnerStatus {
  ACTIVE
  ARCHIVED
}

enum LeaseStatus {
  ACTIVE
  ARCHIVED
  DRAFT
  EXPIRED
  TERMINATED
}

enum UnitType {
  APARTMENT
  OFFICE
  SHOP
  WAREHOUSE
  LAND
  OTHER
}

enum UnitStatus {
  ACTIVE
  ARCHIVED
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  LAND
}

enum PropertyStatus {
  ACTIVE
  ARCHIVED
}

enum UserRole {
  SUPER_ADMIN
  AGENCY_OWNER
  AGENCY_STAFF
  AGENT
  VIEWER
  SYSTEM_ADMIN
}

enum SubscriptionTier {
  BASIC
  PRO
  ENTERPRISE
}

enum AgencyStatus {
  ACTIVE
  SUSPENDED
}
