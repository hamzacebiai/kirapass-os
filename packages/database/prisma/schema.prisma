generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agency {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  email     String   @unique
  phone     String?
  isActive         Boolean          @default(true)
  subscriptionTier SubscriptionTier @default(BASIC)
  status           AgencyStatus     @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  users            User[]
  properties       Property[]
  tenants          Tenant[]
  owners           Owner[]
  messageThreads   MessageThread[]

  @@map("agencies")
}

model User {
  id            String         @id @default(uuid())
  agencyId      String
  email         String         @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          UserRole       @default(AGENT)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  agency        Agency         @relation(fields: [agencyId], references: [id])
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id           String    @id @default(uuid())
  token        String    @unique
  userId       String
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Property {
  id         String         @id @default(uuid())
  agencyId   String
  title      String
  addressLine String
  city       String
  district   String?
  postalCode String?
  notes      String?
  type       PropertyType   @default(RESIDENTIAL)
  status     PropertyStatus @default(ACTIVE)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  agency     Agency         @relation(fields: [agencyId], references: [id])
  ownerId    String?
  owner      Owner?         @relation(fields: [ownerId], references: [id])
  units      Unit[]

  @@index([agencyId])
  @@index([ownerId])
  @@map("properties")
}

model Unit {
  id         String     @id @default(uuid())
  agencyId   String
  propertyId String
  name       String
  unitNumber String
  floor      String?
  notes      String?
  type       UnitType   @default(APARTMENT)
  status     UnitStatus @default(ACTIVE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  property   Property   @relation(fields: [propertyId], references: [id])
  leases     Lease[]

  @@index([agencyId])
  @@index([propertyId])
  @@map("units")
}

model Lease {
  id            String      @id @default(uuid())
  agencyId      String
  unitId        String
  startDate     DateTime
  endDate       DateTime
  rentAmount    Decimal     @db.Decimal(12, 2)
  depositAmount Decimal?    @db.Decimal(12, 2)
  notes         String?
  status        LeaseStatus @default(ACTIVE)
  tenantId      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  unit          Unit           @relation(fields: [unitId], references: [id])
  tenant        Tenant?        @relation(fields: [tenantId], references: [id])
  rentSchedules RentSchedule[]
  messageThreads MessageThread[]
  scoreCycles   TenantScoreCycle[]

  @@index([agencyId])
  @@index([unitId])
  @@index([tenantId])
  @@map("leases")
}

model RentSchedule {
  id        String             @id @default(uuid())
  agencyId  String
  leaseId   String
  tenantId  String?
  dueDate   DateTime
  amount    Decimal            @db.Decimal(12, 2)
  status    RentScheduleStatus @default(PENDING)
  notes     String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  lease     Lease              @relation(fields: [leaseId], references: [id])
  tenant    Tenant?            @relation(fields: [tenantId], references: [id])
  payments  Payment[]

  @@index([agencyId])
  @@index([leaseId])
  @@index([tenantId])
  @@map("rent_schedules")
}

enum RentScheduleStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Payment {
  id             String        @id @default(uuid())
  agencyId       String
  rentScheduleId String
  tenantId       String?
  amount         Decimal       @db.Decimal(12, 2)
  paidAt         DateTime
  method         PaymentMethod @default(CASH)
  reference      String?
  status         PaymentStatus @default(COMPLETED)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  rentSchedule   RentSchedule  @relation(fields: [rentScheduleId], references: [id])
  tenant         Tenant?       @relation(fields: [tenantId], references: [id])

  @@index([agencyId])
  @@index([rentScheduleId])
  @@index([tenantId])
  @@map("payments")
}

model AuditLog {
  id            String   @id @default(uuid())
  eventType     String
  action        String
  resource      String
  method        String?
  statusCode    Int?
  userId        String?
  agencyId      String?
  correlationId String?
  ip            String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([agencyId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
  VOIDED
}

model Tenant {
  id         String       @id @default(uuid())
  agencyId   String
  firstName  String
  lastName   String
  email      String?
  phone      String?
  nationalId String?
  notes      String?
  status     TenantStatus @default(ACTIVE)
  passwordHash    String?
  inviteToken     String?      @unique
  inviteExpiresAt DateTime?
  passwordSetAt   DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  agency        Agency         @relation(fields: [agencyId], references: [id])
  leases        Lease[]
  rentSchedules RentSchedule[]
  payments      Payment[]
  tenantRefreshTokens TenantRefreshToken[]
  messageThreads      MessageThread[]
  scoreCycles         TenantScoreCycle[]
  badges              TenantBadge[]

  @@index([agencyId])
  @@map("tenants")
}

model TenantRefreshToken {
  id        String    @id @default(uuid())
  tenantId  String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_refresh_tokens")
}

model MessageThread {
  id            String       @id @default(uuid())
  agencyId      String
  tenantId      String
  leaseId       String?
  status        ThreadStatus @default(OPEN)
  lastMessageAt DateTime?
  createdAt     DateTime     @default(now())

  agency   Agency    @relation(fields: [agencyId], references: [id])
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  lease    Lease?    @relation(fields: [leaseId], references: [id])
  messages Message[]

  @@index([agencyId])
  @@index([tenantId])
  @@map("message_threads")
}

model Message {
  id          String      @id @default(uuid())
  threadId    String
  senderRole  SenderRole
  senderId    String
  messageType MessageType @default(GENERAL)
  body        String
  sentAt      DateTime    @default(now())
  readAt      DateTime?

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@map("messages")
}

enum ThreadStatus {
  OPEN
  CLOSED
}

enum SenderRole {
  AGENCY
  TENANT
}

enum MessageType {
  GENERAL
  MAINTENANCE
  PAYMENT_QUESTION
  DOCUMENT_REQUEST
}

model TenantScoreCycle {
  id        String                 @id @default(uuid())
  tenantId  String
  leaseId   String
  agencyId  String
  cycleYear Int
  startedAt DateTime
  status    CycleStatus            @default(ACTIVE)
  jokerUsed Boolean                @default(false)
  tenant    Tenant                 @relation(fields: [tenantId], references: [id])
  lease     Lease                  @relation(fields: [leaseId], references: [id])
  events    ScoreEvent[]
  snapshots MonthlyScoreSnapshot[]

  @@index([tenantId])
  @@index([leaseId])
  @@map("tenant_score_cycles")
}

model ScoreEvent {
  id         String           @id @default(uuid())
  cycleId    String
  month      Int
  category   ScoreCategory
  points     Int
  occurredAt DateTime         @default(now())
  cycle      TenantScoreCycle @relation(fields: [cycleId], references: [id])

  @@index([cycleId])
  @@map("score_events")
}

model MonthlyScoreSnapshot {
  id          String           @id @default(uuid())
  cycleId     String
  month       Int
  totalPoints Int
  isPerfect   Boolean
  computedAt  DateTime         @default(now())
  cycle       TenantScoreCycle @relation(fields: [cycleId], references: [id])

  @@unique([cycleId, month])
  @@map("monthly_score_snapshots")
}

model TenantBadge {
  id        String    @id @default(uuid())
  tenantId  String
  badgeType BadgeType
  earnedAt  DateTime  @default(now())
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("tenant_badges")
}

model RewardClaim {
  id         String      @id @default(uuid())
  cycleId    String
  tenantId   String
  leaseId    String
  rentAmount Decimal     @db.Decimal(12, 2)
  status     ClaimStatus @default(ELIGIBLE)
  approvedBy String?
  approvedAt DateTime?
  paidAt     DateTime?
  createdAt  DateTime    @default(now())

  @@map("reward_claims")
}

enum CycleStatus {
  ACTIVE
  COMPLETED
  BROKEN
}

enum ScoreCategory {
  RENT_ONTIME
  MESSAGE_REPLY
  LOGIN_ACTIVITY
  NO_VIOLATION
}

enum BadgeType {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum ClaimStatus {
  ELIGIBLE
  APPROVED
  PAID
  EXPIRED
}

enum TenantStatus {
  ACTIVE
  ARCHIVED
}

model Owner {
  id         String      @id @default(uuid())
  agencyId   String
  firstName  String
  lastName   String
  email      String?
  phone      String?
  status     OwnerStatus @default(ACTIVE)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  agency     Agency      @relation(fields: [agencyId], references: [id])
  properties Property[]

  @@index([agencyId])
  @@map("owners")
}

enum OwnerStatus {
  ACTIVE
  ARCHIVED
}

enum LeaseStatus {
  ACTIVE
  ARCHIVED
  DRAFT
  EXPIRED
  TERMINATED
}

enum UnitType {
  APARTMENT
  OFFICE
  SHOP
  WAREHOUSE
  LAND
  OTHER
}

enum UnitStatus {
  ACTIVE
  ARCHIVED
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  LAND
}

enum PropertyStatus {
  ACTIVE
  ARCHIVED
}

enum UserRole {
  SUPER_ADMIN
  AGENCY_OWNER
  AGENCY_STAFF
  AGENT
  VIEWER
  SYSTEM_ADMIN
}

enum SubscriptionTier {
  BASIC
  PRO
  ENTERPRISE
}

enum AgencyStatus {
  ACTIVE
  SUSPENDED
}
